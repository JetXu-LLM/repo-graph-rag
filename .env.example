# Public Python v2 does not require external credentials.
# The values below are only needed for legacy or experimental paths.

# Legacy / experimental credentials
GITHUB_ACCESS_TOKEN=your_github_token_here
OPENAI_API_KEY=your_openai_api_key_here
HUGGINGFACE_TOKEN=your_huggingface_token_here
MISTRAL_API_KEY=your_mistral_api_key_here
JINA_API_KEY=your_jina_api_key_here

# Legacy Arango path
ARANGODB_HOST=http://localhost:8529
ARANGODB_USERNAME=root
ARANGODB_PASSWORD=your_arangodb_password_here
